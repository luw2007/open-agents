# Minimum runtime
POSTGRES_URL=
JWE_SECRET=

# Required to sign in and store provider tokens
# Must be a 32-byte hex string (64 characters)
# openssl rand -hex 32
ENCRYPTION_KEY=

# App URL (used for metadata and OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitLab OAuth (required for sign-in)
# In GitLab: Settings > Applications > New application
# Redirect URI: {YOUR_ORIGIN}/api/auth/gitlab/callback
# Scopes: openid email profile read_user
GITLAB_URL=https://gitlab.yourcompany.com
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# GitLab Bot Account (required for repo access, pushes, and MRs)
# Create a bot user in GitLab, then generate a Personal Access Token
# Scopes: api read_repository write_repository
GITLAB_BOT_ACCESS_TOKEN=
GITLAB_WEBHOOK_SECRET=

# Optional Redis (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
